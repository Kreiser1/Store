<Window
	x:Class="App.UI.Cart"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:App.UI"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	Title="Корзина"
	Width="450"
	Height="450"
	Closing="Window_CancelClosing"
	ResizeMode="CanResize"
	SourceInitialized="Window_SourceInitialized"
	Topmost="True"
	WindowStartupLocation="CenterOwner"
	mc:Ignorable="d">
	<Grid Margin="15">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<DockPanel
			Grid.Row="0"
			Grid.Column="0"
			Margin="5">
			<TextBlock
				HorizontalAlignment="Left"
				VerticalAlignment="Center"
				FontSize="22"
				FontWeight="Bold"
				Text="Корзина" />
			<Button
				Name="ClearButton"
				Width="52"
				Height="32"
				HorizontalAlignment="Right"
				Background="#007ACC"
				BorderThickness="0"
				Click="ClearButton_Click"
				Content="🧹"
				Cursor="Hand"
				FontSize="14"
				FontWeight="SemiBold"
				Foreground="White" />
		</DockPanel>

		<ListBox
			Name="CartListBox"
			Grid.Row="1"
			Grid.Column="0"
			Margin="5"
			HorizontalAlignment="Stretch"
			VerticalAlignment="Stretch"
			ScrollViewer.HorizontalScrollBarVisibility="Disabled"
			ScrollViewer.VerticalScrollBarVisibility="Auto">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Grid Margin="5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="120" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>

						<Image
							Grid.Column="0"
							Margin="0,0,10,0"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Stretch"
							Source="{Binding Image, TargetNullValue={x:Null}}"
							Stretch="Fill" />

						<StackPanel Grid.Column="1" VerticalAlignment="Center">
							<TextBlock
								FontSize="16"
								FontWeight="Bold"
								Text="{Binding Name}" />

							<TextBlock
								FontSize="12"
								Foreground="Gray"
								Text="{Binding Manufacturer, StringFormat='Производитель: {0}', TargetNullValue='Не указан'}" />

							<TextBlock
								Margin="0,3,0,5"
								FontSize="13"
								FontStyle="Italic"
								Text="{Binding Description, TargetNullValue='Описание отсутствует.'}"
								TextTrimming="CharacterEllipsis" />

							<WrapPanel Orientation="Horizontal">
								<TextBlock
									Margin="3,0,5,0"
									Text="{Binding Price, StringFormat='{}{0} руб.'}"
									TextDecorations="Strikethrough">
									<TextBlock.Style>
										<Style TargetType="TextBlock">
											<Setter Property="Visibility" Value="Visible" />
											<Style.Triggers>
												<DataTrigger Binding="{Binding Discount}" Value="{x:Null}">
													<Setter Property="Visibility" Value="Collapsed" />
												</DataTrigger>
												<DataTrigger Binding="{Binding Discount}" Value="0">
													<Setter Property="Visibility" Value="Collapsed" />
												</DataTrigger>
											</Style.Triggers>
										</Style>
									</TextBlock.Style>
								</TextBlock>

								<TextBlock
									Margin="3,0,5,0"
									FontWeight="SemiBold"
									Text="{Binding RealPrice, StringFormat='{}{0} руб.'}" />

								<TextBlock
									Margin="3,0,10,0"
									Foreground="Gray"
									Text="{Binding Unit, StringFormat='/ {0}', TargetNullValue='шт.'}" />

								<TextBlock
									FontWeight="Bold"
									Foreground="Crimson"
									Text="{Binding Discount, StringFormat='Скидка: {0}%', TargetNullValue=''}" />
							</WrapPanel>

							<TextBlock FontStyle="Italic" Text="{Binding Count, StringFormat='К заказу: {0}', TargetNullValue=''}" />
						</StackPanel>
					</Grid>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>

		<Button
			Name="OrderButton"
			Grid.Row="2"
			Height="32"
			Margin="5"
			HorizontalAlignment="Stretch"
			Background="#007ACC"
			BorderThickness="0"
			Click="OrderButton_Click"
			Content="Заказать"
			Cursor="Hand"
			DockPanel.Dock="Right"
			FontSize="14"
			FontWeight="SemiBold"
			Foreground="White" />

	</Grid>


</Window>