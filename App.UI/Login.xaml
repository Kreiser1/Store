<Window
	x:Class="App.UI.Login"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:App.UI"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	Title="Авторизация"
	Width="350"
	Height="450"
	ResizeMode="NoResize"
	ShowInTaskbar="False"
	Topmost="True"
	WindowStartupLocation="CenterScreen"
	mc:Ignorable="d">

	<Grid>
		<StackPanel
			Width="250"
			HorizontalAlignment="Center"
			VerticalAlignment="Center">
			<TextBlock
				Margin="0,0,0,25"
				HorizontalAlignment="Center"
				FontSize="22"
				FontWeight="Bold"
				Text="Вход в систему" />

			<TextBlock
				Margin="0,0,0,3"
				FontSize="14"
				Foreground="#666666"
				Text="Логин" />

			<TextBox
				Name="LoginTextBox"
				Height="32"
				Margin="0,0,0,15"
				Padding="5,0"
				VerticalContentAlignment="Center" />

			<TextBlock
				Margin="0,0,0,3"
				FontSize="14"
				Foreground="#666666"
				Text="Пароль" />

			<PasswordBox
				Name="PasswordTextBox"
				Height="32"
				Margin="0,0,0,25"
				Padding="5,0"
				VerticalContentAlignment="Center" />

			<Button
				Name="LoginButton"
				Height="32"
				Background="#007ACC"
				BorderThickness="0"
				Click="LoginButton_Click"
				Content="Войти"
				Cursor="Hand"
				FontSize="14"
				FontWeight="SemiBold"
				Foreground="White" />

			<Label Margin="0,10,0,0">
				<Hyperlink Click="Hyperlink_LoginAsGuest">Войти как гость...</Hyperlink>
			</Label>
			<Label>
				<Hyperlink Click="Hyperlink_Register">Регистрация...</Hyperlink>
			</Label>
		</StackPanel>
	</Grid>
</Window>