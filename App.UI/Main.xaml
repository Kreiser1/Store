<Window
	x:Class="App.UI.Main"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:App.UI"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	Title="Главная"
	Width="800"
	Height="450"
	Loaded="Window_Loaded"
	ResizeMode="CanResize"
	WindowStartupLocation="CenterScreen"
	mc:Ignorable="d">
	<Grid Margin="15">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" MinWidth="400" />
			<ColumnDefinition Width="3" />
			<ColumnDefinition Width="300" MinWidth="200" />
		</Grid.ColumnDefinitions>

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<DockPanel
			Grid.Row="0"
			Grid.Column="0"
			Margin="5">
			<TextBlock
				HorizontalAlignment="Left"
				VerticalAlignment="Center"
				FontSize="22"
				FontWeight="Bold"
				Text="Каталог" />
			<Button
				Name="AddButton"
				Width="52"
				Height="32"
				HorizontalAlignment="Right"
				Background="#007ACC"
				BorderThickness="0"
				Click="AddButton_Click"
				Content="➕"
				Cursor="Hand"
				FontSize="14"
				FontWeight="SemiBold"
				Foreground="White" />
		</DockPanel>

		<ListBox
			Name="CatalogueListBox"
			Grid.Row="1"
			Grid.Column="0"
			Margin="5"
			HorizontalAlignment="Stretch"
			VerticalAlignment="Stretch"
			ScrollViewer.HorizontalScrollBarVisibility="Disabled"
			ScrollViewer.VerticalScrollBarVisibility="Auto">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Grid Margin="5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="120" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>

						<Image
							Grid.Column="0"
							Margin="0,0,10,0"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Stretch"
							Source="{Binding Image, TargetNullValue={x:Null}}"
							Stretch="Fill" />

						<StackPanel Grid.Column="1" VerticalAlignment="Center">
							<TextBlock
								FontSize="16"
								FontWeight="Bold"
								Text="{Binding Name}" />

							<TextBlock
								FontSize="12"
								Foreground="Gray"
								Text="{Binding Manufacturer, StringFormat='Производитель: {0}', TargetNullValue='Не указан'}" />

							<TextBlock
								Margin="0,3,0,5"
								FontSize="13"
								FontStyle="Italic"
								Text="{Binding Description, TargetNullValue='Описание отсутствует.'}"
								TextTrimming="CharacterEllipsis" />

							<WrapPanel Orientation="Horizontal">
								<TextBlock
									Margin="3,0,5,0"
									Text="{Binding Price, StringFormat='{}{0} руб.'}"
									TextDecorations="Strikethrough" />

								<TextBlock
									Margin="3,0,5,0"
									FontWeight="SemiBold"
									Text="{Binding RealPrice, StringFormat='{}{0} руб.'}" />

								<TextBlock
									Margin="3,0,10,0"
									Foreground="Gray"
									Text="{Binding Unit, StringFormat='/ {0}', TargetNullValue='шт.'}" />

								<TextBlock
									FontWeight="Bold"
									Foreground="Red"
									Text="{Binding Discount, StringFormat='Скидка: {0}%', TargetNullValue=''}" />
							</WrapPanel>

							<WrapPanel Orientation="Horizontal">
								<Button
									Height="32"
									Margin="0,10,0,5"
									Padding="5"
									Background="#007ACC"
									BorderThickness="0"
									Click="AddToCartButton_Click"
									Content="Добавить в корзину"
									Cursor="Hand"
									FontSize="14"
									FontWeight="SemiBold"
									Foreground="White" />
							</WrapPanel>
						</StackPanel>
					</Grid>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>


		<DockPanel
			Grid.Row="2"
			Grid.Column="0"
			Margin="5">
			<Button
				Name="RefreshButton"
				Width="52"
				Height="32"
				HorizontalAlignment="Right"
				Background="#007ACC"
				BorderThickness="0"
				Click="RefreshButton_Click"
				Content="⟳"
				Cursor="Hand"
				DockPanel.Dock="Right"
				FontSize="14"
				FontWeight="SemiBold"
				Foreground="White" />
			<TextBox
				Name="SearchTextBox"
				Height="32"
				Margin="0,0,5,0"
				Padding="5,0"
				HorizontalAlignment="Stretch"
				VerticalContentAlignment="Center"
				TextChanged="SearchTextBox_TextChanged" />
		</DockPanel>

		<GridSplitter
			Grid.Row="0"
			Grid.RowSpan="3"
			Grid.Column="1"
			Width="1"
			HorizontalAlignment="Stretch"
			VerticalAlignment="Stretch" />

		<DockPanel
			Grid.Row="0"
			Grid.Column="2"
			Margin="5">
			<DockPanel>
				<Button
					Name="EditProfileButton"
					Width="52"
					Height="32"
					Margin="5,0,0,0"
					Background="#007ACC"
					BorderThickness="0"
					Click="EditProfileButton_Click"
					Content="✎"
					Cursor="Hand"
					DockPanel.Dock="Right"
					FontSize="14"
					FontWeight="SemiBold"
					Foreground="White" />
				<TextBlock
					Name="UsernameTextBox"
					VerticalAlignment="Center"
					FontSize="18"
					FontWeight="SemiBold"
					Text="..." />
			</DockPanel>
		</DockPanel>

		<ListBox
			Name="OrdersListBox"
			Grid.Row="1"
			Grid.Column="2"
			Margin="5"
			HorizontalAlignment="Stretch"
			VerticalAlignment="Stretch"
			ScrollViewer.HorizontalScrollBarVisibility="Disabled"
			ScrollViewer.VerticalScrollBarVisibility="Auto" />

		<DockPanel
			Grid.Row="2"
			Grid.Column="2"
			Margin="5">
			<Button
				Name="CartButton"
				Width="52"
				Height="32"
				HorizontalAlignment="Right"
				Background="#007ACC"
				BorderThickness="0"
				Click="CartButton_Click"
				Content="🛒"
				Cursor="Hand"
				FontSize="14"
				FontWeight="SemiBold"
				Foreground="White" />
		</DockPanel>
	</Grid>


</Window>