<Window
	x:Class="App.UI.ProductEditor"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:App.UI"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	Title="Редактирование продукта"
	Width="640"
	Height="400"
	SourceInitialized="Window_SourceInitialized"
	Topmost="True"
	WindowStartupLocation="CenterOwner"
	mc:Ignorable="d">

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" MinWidth="200" />
			<ColumnDefinition Width="*" MinWidth="400" />
		</Grid.ColumnDefinitions>

		<DockPanel Grid.Column="0">
			<Button
				Name="AttachImageButton"
				Height="36"
				Margin="5,5,5,5"
				HorizontalAlignment="Stretch"
				VerticalAlignment="Bottom"
				Background="#007ACC"
				BorderThickness="0"
				Click="AttachImageButton_Click"
				Content="Прикрепить картинку"
				Cursor="Hand"
				DockPanel.Dock="Bottom"
				FontSize="14"
				FontWeight="SemiBold"
				Foreground="White" />

			<Image
				Name="ProductImage"
				Margin="10,10,10,10"
				HorizontalAlignment="Stretch"
				VerticalAlignment="Stretch"
				Source="{Binding Image, TargetNullValue={x:Null}}"
				Stretch="Fill" />

		</DockPanel>
		<ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
			<StackPanel>
				<TextBlock
					Margin="10,10,10,10"
					HorizontalAlignment="Stretch"
					FontSize="22"
					FontWeight="SemiBold"
					Text="Редактирование продукта"
					TextAlignment="Left"
					TextWrapping="Wrap" />

				<TextBlock
					Margin="5,0,5,3"
					FontSize="14"
					Foreground="#666666"
					Text="Название *" />
				<TextBox
					Name="NameTextBox"
					Height="32"
					Margin="5,0,10,5"
					Padding="5,0"
					VerticalAlignment="Stretch"
					VerticalContentAlignment="Center"
					MaxLength="50" />

				<TextBlock
					Margin="5,0,10,3"
					FontSize="14"
					Foreground="#666666"
					Text="Цена *" />
				<TextBox
					Name="PriceTextBox"
					Height="32"
					Margin="5,0,10,5"
					Padding="5,0"
					VerticalAlignment="Stretch"
					VerticalContentAlignment="Center"
					MaxLength="50" />

				<TextBlock
					Margin="5,0,10,3"
					FontSize="14"
					Foreground="#666666"
					Text="Количество *" />
				<TextBox
					Name="CountTextBox"
					Height="32"
					Margin="5,0,10,5"
					Padding="5,0"
					VerticalAlignment="Stretch"
					VerticalContentAlignment="Center"
					MaxLength="50" />

				<TextBlock
					Margin="5,0,10,3"
					FontSize="14"
					Foreground="#666666"
					Text="Описание" />
				<TextBox
					Name="DescriptionTextBox"
					Height="128"
					Margin="5,0,10,5"
					Padding="5,5"
					VerticalAlignment="Stretch"
					AcceptsReturn="True"
					HorizontalScrollBarVisibility="Disabled"
					MaxLength="1000"
					TextWrapping="Wrap"
					VerticalScrollBarVisibility="Auto" />

				<TextBlock
					Margin="5,0,10,3"
					FontSize="14"
					Foreground="#666666"
					Text="Единица измерения" />
				<TextBox
					Name="UnitTextBox"
					Height="32"
					Margin="5,0,10,5"
					Padding="5,0"
					VerticalAlignment="Stretch"
					VerticalContentAlignment="Center"
					MaxLength="50" />

				<TextBlock
					Margin="5,0,10,3"
					FontSize="14"
					Foreground="#666666"
					Text="Производитель" />
				<TextBox
					Name="ManufacturerTextBox"
					Height="32"
					Margin="5,0,10,5"
					Padding="5,0"
					VerticalAlignment="Stretch"
					VerticalContentAlignment="Center"
					MaxLength="50" />

				<TextBlock
					Margin="5,0,10,3"
					FontSize="14"
					Foreground="#666666"
					Text="Поставщик" />
				<TextBox
					Name="ProviderTextBox"
					Height="32"
					Margin="5,0,10,5"
					Padding="5,0"
					VerticalAlignment="Stretch"
					VerticalContentAlignment="Center"
					MaxLength="50" />

				<TextBlock
					Margin="5,0,10,3"
					FontSize="14"
					Foreground="#666666"
					Text="Скидка %" />
				<TextBox
					Name="DiscountTextBox"
					Height="32"
					Margin="5,0,10,5"
					Padding="5,0"
					VerticalAlignment="Stretch"
					VerticalContentAlignment="Center"
					MaxLength="50" />

				<Button
					Name="FinishButton"
					Height="36"
					Margin="5,5,10,5"
					HorizontalAlignment="Stretch"
					Background="#007ACC"
					BorderThickness="0"
					Click="FinishButton_Click"
					Content="Завершить"
					Cursor="Hand"
					FontSize="14"
					FontWeight="SemiBold"
					Foreground="White" />
			</StackPanel>
		</ScrollViewer>
	</Grid>
</Window>