<Window
	x:Class="App.UI.Admin"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:App.UI"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	Title="Администрирование"
	Width="1200"
	Height="600"
	Loaded="Window_Loaded"
	ResizeMode="CanResize"
	SourceInitialized="Window_SourceInitialized"
	WindowStartupLocation="CenterScreen"
	mc:Ignorable="d">
	<Grid Margin="15">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" MinWidth="350" />
			<ColumnDefinition Width="3" />
			<ColumnDefinition Width="*" MinWidth="300" />
			<ColumnDefinition Width="3" />
			<ColumnDefinition Width="*" MinWidth="300" />
		</Grid.ColumnDefinitions>

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<DockPanel
			Grid.Row="0"
			Grid.Column="0"
			Margin="5">
			<TextBlock
				HorizontalAlignment="Left"
				VerticalAlignment="Center"
				FontSize="22"
				FontWeight="Bold"
				Text="Каталог" />
		</DockPanel>

		<ListBox
			Name="CatalogueListBox"
			Grid.Row="1"
			Grid.Column="0"
			Margin="5"
			HorizontalAlignment="Stretch"
			VerticalAlignment="Stretch"
			ScrollViewer.HorizontalScrollBarVisibility="Disabled"
			ScrollViewer.VerticalScrollBarVisibility="Auto">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Grid Margin="5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="120" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>

						<Image
							Grid.Column="0"
							Margin="0,0,10,0"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Stretch"
							Source="{Binding Image, TargetNullValue={x:Null}}"
							Stretch="Fill" />

						<StackPanel Grid.Column="1" VerticalAlignment="Center">
							<TextBlock
								FontSize="16"
								FontWeight="Bold"
								Text="{Binding Name}" />

							<TextBlock
								FontSize="12"
								Foreground="Gray"
								Text="{Binding Manufacturer, StringFormat='Производитель: {0}', TargetNullValue='Не указан'}" />

							<TextBlock
								Margin="0,3,0,5"
								FontSize="13"
								FontStyle="Italic"
								Text="{Binding Description, TargetNullValue='Описание отсутствует.'}"
								TextTrimming="CharacterEllipsis" />

							<WrapPanel Orientation="Horizontal">
								<TextBlock
									Margin="3,0,5,0"
									Text="{Binding Price, StringFormat='{}{0} руб.'}"
									TextDecorations="Strikethrough" />

								<TextBlock
									Margin="3,0,5,0"
									FontWeight="SemiBold"
									Text="{Binding RealPrice, StringFormat='{}{0} руб.'}" />

								<TextBlock
									Margin="3,0,10,0"
									Foreground="Gray"
									Text="{Binding Unit, StringFormat='/ {0}', TargetNullValue='шт.'}" />

								<TextBlock
									FontWeight="Bold"
									Foreground="Crimson"
									Text="{Binding Discount, StringFormat='Скидка: {0}%', TargetNullValue=''}" />
							</WrapPanel>

							<TextBlock FontStyle="Italic" Text="{Binding Count, StringFormat='В наличии: {0}', TargetNullValue=''}" />

							<WrapPanel Margin="0,10,0,5" Orientation="Horizontal">
								<Button
									Height="32"
									Margin="0,0,5,0"
									Padding="15,0"
									Background="#007ACC"
									BorderThickness="0"
									Click="Button_Click"
									Content="Изменить"
									Cursor="Hand"
									FontSize="13"
									FontWeight="SemiBold"
									Foreground="White" />
								<Button
									Height="32"
									Padding="15,0"
									Background="Crimson"
									BorderThickness="0"
									Click="Button_Click_1"
									Content="Удалить"
									Cursor="Hand"
									FontSize="13"
									FontWeight="SemiBold"
									Foreground="White" />
							</WrapPanel>
						</StackPanel>
					</Grid>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>

		<DockPanel
			Grid.Row="2"
			Grid.Column="0"
			Margin="5">
			<TextBox
				Name="SearchTextBox"
				Height="32"
				Padding="5,0"
				HorizontalAlignment="Stretch"
				VerticalContentAlignment="Center"
				MaxLength="100"
				TextChanged="SearchTextBox_TextChanged" />
		</DockPanel>

		<GridSplitter
			Grid.Row="0"
			Grid.RowSpan="3"
			Grid.Column="1"
			Width="2"
			HorizontalAlignment="Stretch"
			VerticalAlignment="Stretch" />

		<DockPanel
			Grid.Row="0"
			Grid.Column="2"
			Margin="5">
			<TextBlock
				VerticalAlignment="Center"
				FontSize="22"
				FontWeight="Bold"
				Text="Пользователи" />
		</DockPanel>

		<ListBox
			Name="UsersListBox"
			Grid.Row="1"
			Grid.Column="2"
			Margin="5"
			HorizontalAlignment="Stretch"
			VerticalAlignment="Stretch"
			ScrollViewer.HorizontalScrollBarVisibility="Disabled"
			ScrollViewer.VerticalScrollBarVisibility="Auto">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Grid Margin="5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>

						<StackPanel Grid.Column="0" VerticalAlignment="Center">
							<TextBlock
								FontSize="15"
								FontWeight="Bold"
								Text="{Binding Username, TargetNullValue='Без имени'}" />
							<TextBlock
								FontSize="12"
								Foreground="Gray"
								Text="{Binding Role, StringFormat='Роль: {0}', TargetNullValue='Пользователь'}" />
						</StackPanel>

						<Button
							Grid.Column="1"
							Height="32"
							Padding="15,0"
							VerticalAlignment="Center"
							Background="Crimson"
							BorderThickness="0"
							Click="Button_Click_2"
							Content="Удалить"
							Cursor="Hand"
							FontSize="13"
							FontWeight="SemiBold"
							Foreground="White" />
					</Grid>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>

		<Grid Grid.Row="2" Grid.Column="2" />

		<GridSplitter
			Grid.Row="0"
			Grid.RowSpan="3"
			Grid.Column="3"
			Width="2"
			HorizontalAlignment="Stretch"
			VerticalAlignment="Stretch" />

		<DockPanel
			Grid.Row="0"
			Grid.Column="4"
			Margin="5">
			<TextBlock
				VerticalAlignment="Center"
				FontSize="22"
				FontWeight="Bold"
				Text="Заказы" />
		</DockPanel>

		<ListBox
			Name="OrdersListBox"
			Grid.Row="1"
			Grid.Column="4"
			Margin="5"
			HorizontalAlignment="Stretch"
			VerticalAlignment="Stretch"
			ScrollViewer.HorizontalScrollBarVisibility="Disabled"
			ScrollViewer.VerticalScrollBarVisibility="Auto">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Grid Margin="5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>

						<StackPanel Grid.Column="0" VerticalAlignment="Center">
							<TextBlock
								FontSize="15"
								FontWeight="Bold"
								Text="{Binding Id, StringFormat='Заказ №{0}'}" />
							<TextBlock
								FontSize="12"
								Foreground="Gray"
								Text="{Binding Status, StringFormat='Статус: {0}'}" />
							<TextBlock
								FontSize="13"
								FontWeight="SemiBold"
								Text="{Binding TotalPrice, StringFormat='Сумма: {0} руб.'}" />
						</StackPanel>

						<Button
							Grid.Column="1"
							Height="32"
							Padding="15,0"
							VerticalAlignment="Center"
							Background="Crimson"
							BorderThickness="0"
							Click="Button_Click_3"
							Content="Удалить"
							Cursor="Hand"
							FontSize="13"
							FontWeight="SemiBold"
							Foreground="White" />
					</Grid>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>

		<Grid Grid.Row="2" Grid.Column="4" />
	</Grid>
</Window>
