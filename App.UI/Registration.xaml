<Window
	x:Class="App.UI.Registration"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:App.UI"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	Title="Регистрация"
	Width="400"
	Height="550"
	ResizeMode="NoResize"
	Topmost="True"
	WindowStartupLocation="CenterScreen"
	mc:Ignorable="d">

	<Grid>
		<StackPanel
			Width="280"
			HorizontalAlignment="Center"
			VerticalAlignment="Center">

			<TextBlock
				Margin="0,0,0,20"
				HorizontalAlignment="Center"
				FontSize="22"
				FontWeight="SemiBold"
				Text="Регистрация"
				TextAlignment="Center"
				TextWrapping="Wrap" />

			<TextBlock
				Margin="0,0,0,3"
				FontSize="14"
				Foreground="#666666"
				Text="Логин *" />
			<TextBox
				Name="LoginTextBox"
				Height="32"
				Margin="0,0,0,5"
				Padding="5,0"
				VerticalContentAlignment="Center"
				MaxLength="50" />

			<TextBlock
				Margin="0,0,0,3"
				FontSize="14"
				Foreground="#666666"
				Text="Пароль *" />
			<PasswordBox
				Name="PasswordTextBox"
				Height="32"
				Margin="0,0,0,5"
				Padding="5,0"
				VerticalContentAlignment="Center"
				MaxLength="50" />

			<TextBlock
				Margin="0,0,0,3"
				FontSize="14"
				Foreground="#666666"
				Text="Подтверждение пароля *" />
			<PasswordBox
				Name="ConfirmPasswordTextBox"
				Height="32"
				Margin="0,0,0,5"
				Padding="5,0"
				VerticalContentAlignment="Center"
				MaxLength="50" />

			<TextBlock
				Margin="0,0,0,3"
				FontSize="14"
				Foreground="#666666"
				Text="Имя (необязательно)" />
			<TextBox
				Name="NameTextBox"
				Height="32"
				Margin="0,0,0,20"
				Padding="5,0"
				VerticalContentAlignment="Center"
				MaxLength="100" />

			<Button
				Name="RegisterButton"
				Height="36"
				Background="#007ACC"
				BorderThickness="0"
				Click="RegisterButton_Click"
				Content="Зарегистрироваться"
				Cursor="Hand"
				FontSize="14"
				FontWeight="SemiBold"
				Foreground="White" />

			<Label Margin="0,10,0,0" HorizontalAlignment="Center">
				<Hyperlink Click="Hyperlink_BackToLogin">Вернуться ко входу...</Hyperlink>
			</Label>
		</StackPanel>
	</Grid>
</Window>